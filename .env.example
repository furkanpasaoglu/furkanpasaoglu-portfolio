# Copy to `.env` and fill values.
#
# In production (Dokploy etc.), set these as environment variables in the
# dashboard instead of uploading a .env file.

# ── PostgreSQL ────────────────────────────────────────────────────────
# Generate a strong random: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-password

# ── Keycloak (centralized IdP) ────────────────────────────────────────
# Realm authority URL (no trailing slash). e.g. https://keycloak.furkanpasaoglu.com/realms/blog
KEYCLOAK_AUTHORITY=https://keycloak.example.com/realms/blog
# Client ID configured in Keycloak (Confidential, Standard flow + PKCE)
KEYCLOAK_CLIENT_ID=portfolio-admin
# Client secret from Keycloak → Clients → Credentials
KEYCLOAK_CLIENT_SECRET=change-me-from-keycloak-credentials

# Public origin (scheme + host) of THIS site, used to build the OIDC redirect_uri.
# Must match a Valid redirect URI in Keycloak (e.g. https://furkanpasaoglu.com/api/admin/auth/callback).
PUBLIC_ORIGIN=https://example.com

# ── Client (nginx) host port ──────────────────────────────────────────
# Public port for the site + admin. On Dokploy this is handled by the
# built-in Traefik, so you can leave CLIENT_PORT unset there.
CLIENT_PORT=80
