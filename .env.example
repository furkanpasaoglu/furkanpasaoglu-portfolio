# Copy to `.env` and fill values.
#
# In production (Dokploy etc.), set these as environment variables in the
# dashboard instead of uploading a .env file.

# ── PostgreSQL ────────────────────────────────────────────────────────
# Generate a strong random: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-password

# ── JWT ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-at-least-32-chars-long-random

# ── Admin seed ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate: openssl rand -base64 24
ADMIN_PASSWORD=change-me-too

# Set to `true` to re-hash admin password from above on next restart (emergency reset).
ADMIN_RESET=false

# ── Client (nginx) host port ──────────────────────────────────────────
# Public port for the site + admin. On Dokploy this is handled by the
# built-in Traefik, so you can leave CLIENT_PORT unset there.
CLIENT_PORT=80
